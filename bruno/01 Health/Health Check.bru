meta {
  name: Health Check
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/health/
  body: none
  auth: none
}

tests {
  test("returns an OK health response", function () {
    expect(res.getStatus()).to.equal(200);
    expect(res.body.success).to.equal(true);
    expect(res.body.data.status).to.equal("ok");
  });
}
