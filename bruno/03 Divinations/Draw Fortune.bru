meta {
  name: Draw Fortune
  type: http
  seq: 4
}

post {
  url: {{baseUrl}}/divinations/{{sessionId}}/draw/
  body: none
  auth: none
}

tests {
  test("draws an active fortune", function () {
    expect(res.getStatus()).to.equal(200);
    expect(res.body.success).to.equal(true);
    expect(res.body.data.status).to.equal("waiting_for_blocks");
    expect(res.body.data.fortune.number).to.be.a("number");
  });
}
