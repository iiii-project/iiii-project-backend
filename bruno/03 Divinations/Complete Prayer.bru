post {
  url: {{baseUrl}}/divinations/{{sessionId}}/prayer-complete/
  body: none
  auth: none
}

tests {
  test("moves the session to drawing", function () {
    expect(res.getStatus()).to.equal(200);
    expect(res.body.success).to.equal(true);
    expect(res.body.data.status).to.equal("drawing");
  });
}
