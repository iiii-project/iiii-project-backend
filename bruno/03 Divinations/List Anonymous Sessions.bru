meta {
  name: List Anonymous Sessions
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/divinations/?anonymous_user_id={{anonymousUserId}}
  body: none
  auth: none
}

tests {
  test("returns the anonymous session list", function () {
    expect(res.getStatus()).to.equal(200);
    expect(res.body.success).to.equal(true);
    expect(res.body.data.items).to.be.an("array");
  });
}
