meta {
  name: Refresh JWT
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/auth/token/refresh/
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "refresh": "{{refreshToken}}"
  }
}

tests {
  test("returns a refreshed access token", function () {
    expect(res.getStatus()).to.equal(200);
    expect(res.body.access).to.be.a("string").and.not.empty;
  });
}

script:post-response {
  bru.setVar("accessToken", res.body.access);
}
