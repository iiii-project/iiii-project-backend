meta {
  name: Get Current User
  type: http
  seq: 4
}

get {
  url: {{baseUrl}}/auth/me/
  body: none
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

tests {
  test("returns the authenticated user", function () {
    expect(res.getStatus()).to.equal(200);
    expect(res.body.success).to.equal(true);
    expect(res.body.data.username).to.equal(bru.getEnvVar("username"));
  });
}
